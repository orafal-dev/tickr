# syntax=docker/dockerfile:1

FROM oven/bun:1.3 AS pruner
WORKDIR /app
ENV TURBO_TELEMETRY_DISABLED=1
COPY . .
RUN bun install --frozen-lockfile
RUN bunx turbo prune web --docker

FROM oven/bun:1.3 AS builder
WORKDIR /app
ENV TURBO_TELEMETRY_DISABLED=1
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/bun.lock bun.lock
# Pruned lockfiles can disagree with Bun's resolver; skip --frozen-lockfile here.
RUN bun install
COPY --from=pruner /app/out/full/ .
# Raise heap for Next.js compile; if the Docker builder still gets SIGKILL, allocate more RAM/swap to Docker.
ENV NODE_OPTIONS=--max-old-space-size=6144
RUN bun run turbo build --filter=web
RUN rm -rf /app/apps/web/.next/cache

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=5 \
  CMD node -e "fetch('http://127.0.0.1:3000/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "apps/web/server.js"]
