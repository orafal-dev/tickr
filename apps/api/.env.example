# Same Postgres database as Better Auth / apps/web
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/tickr

# Optional URL override (checked before PG* / DATABASE_URL), e.g. sslmode=require:
# API_DATABASE_URL=

# Or use PG* instead of DATABASE_URL (passwords can contain @, &, etc. without URL encoding):
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=tickr
# PGPASSWORD=postgres
# PGDATABASE=tickr

# Must match apps/web `API_INTERNAL_KEY` (sent as `x-api-internal-key`)
API_INTERNAL_KEY=local-development-api-internal-key

# Optional — defaults to 3001 in main.ts when unset
# API_PORT=3001
