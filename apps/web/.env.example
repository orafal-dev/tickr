# Better Auth — https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Better Auth Infrastructure (dash + sentinel) — https://www.better-auth.com/docs/infrastructure
# Required in production. Optional locally; leave unset to run auth without Infra telemetry/security APIs.
BETTER_AUTH_API_KEY=

# Used by the browser auth client when calling /api/auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth (optional). When both id and secret are set for a provider, it appears on login/register.
# Redirect URIs (local): http://localhost:3000/api/auth/callback/google
#   · http://localhost:3000/api/auth/callback/github
#   · http://localhost:3000/api/auth/callback/linear
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=

# PostgreSQL (Better Auth tables — run `bun run auth:migrate` in apps/web)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/tickr

# Nest API base URL for `apiFetch` in lib/api.ts
API_URL=http://localhost:3001

# Shared secret for server-to-server calls from Next to Nest (`x-api-internal-key`).
# Must match `API_INTERNAL_KEY` on the API process. Never expose to the browser.
API_INTERNAL_KEY=local-development-api-internal-key

# useSend (recommended for production/self-hosted)
# USESEND_API_KEY=us_xxxxxxxxxxxxxxxxxxxxx
# USESEND_BASE_URL=https://usesend-wcw0o04ckwss04wwwkwo0kok.botox.boo
#
# SMTP fallback (used when USESEND_API_KEY is not set)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=Tickr <noreply@localhost>
# Optional when Mailpit auth is enabled
# SMTP_USER=
# SMTP_PASSWORD=
